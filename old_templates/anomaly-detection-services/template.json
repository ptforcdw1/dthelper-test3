{
  "responseTime": {
    "enabled": true,
    "detectionMode": "fixed",
    "fixedDetection": {
      "responseTimeAll": {
        "degradationMilliseconds": {{ .degradationMs }}
      },
      "responseTimeSlowest": {
        "slowestDegradationMilliseconds": {{ .slowestDegradationMs }}
      },
      "overAlertingProtection": {
        "requestsPerMinute": 10,
        "minutesAbnormalState": 1
      },
      "sensitivity": "{{ .sensitivity }}"
    }
  },
  "failureRate": {
    "enabled": true,
    "detectionMode": "auto",
    "autoDetection": {
      "absoluteIncrease": 0.0,
      "relativeIncrease": 50.0,
      "overAlertingProtection": {
        "requestsPerMinute": 10,
        "minutesAbnormalState": 1
      }
    }
  },
  "loadDrops": {
    "enabled": false
  },
  "loadSpikes": {
    "enabled": false
  }
}
