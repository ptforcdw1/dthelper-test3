# Copy to webform/.env and fill in.
# Never commit webform/.env to source control.

# --- repo to clone --------------------------------------------------------
REPO_URL=https://github.com/ptforcdw1/dthelper-test3.git
REPO_BRANCH=main

# GitHub personal access token with "Contents: write" on the target repo.
# Used by git_ops.py to push the new task commit.
GITHUB_PAT=ghp_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Where the form's checkout lives on disk. Cleared and re-cloned if absent.
WORK_DIR=/tmp/dthelper-webform

# --- Jenkins --------------------------------------------------------------
# Reachable URL from inside the form container/process.
# Docker Desktop: http://host.docker.internal:8080 OR http://jenkins:8080 if on a shared user network.
JENKINS_URL=http://host.docker.internal:8080
JENKINS_USER=admin
JENKINS_API_TOKEN=00000000000000000000000000000000
JENKINS_JOB=DTHelper-v3-monaco-mvp2

# --- Defaults the form passes to Jenkins ---------------------------------
TARGET_ENVIRONMENT=ylq89164

# --- Commit metadata ------------------------------------------------------
GIT_USER_NAME=monaco-webform
GIT_USER_EMAIL=monaco-webform@example.com
