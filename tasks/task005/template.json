{
  "enabled": true,
  "name": "{{ .ruleName }}",
  "description": "Auto-renames matching Tomcat service: overrides serverName to {{ .serviceName }}",
  "idContributors": {
    "detectAsWebRequestService": false,
    "applicationId": { "enableIdContributor": false },
    "contextRoot": { "enableIdContributor": false },
    "serverName": {
      "enableIdContributor": true,
      "serviceIdContributor": {
        "contributionType": "OverrideValue",
        "valueOverride": { "value": "{{ .serviceName }}" }
      }
    },
    "webServiceName": { "enableIdContributor": false },
    "webServiceNamespace": { "enableIdContributor": false }
  },
  "conditions": [
    {
      "attribute": "PG_Name",
      "compareOperationType": "StringContains",
      "textValues": ["{{ .processGroupMatch }}"],
      "ignoreCase": true
    }
  ]
}
