{
  "enabled": true,
  "title": "{{ .title }}",
  "description": "",
  "source": "Rest API",
  "executionSettings": {
    "actor": "331225d3-68b1-4dbb-ae89-c483d7ec851c"
  },
  "analyzer": {
    "name": "dt.statistics.ui.anomaly_detection.StaticThresholdAnomalyDetectionAnalyzer",
    "input": [
      {
        "key": "query.expression",
        "value": "timeseries responseTime_p50_timeseries = percentile(dt.service.request.response_time, 50),\n  filter: {dt.entity.service.name == \"{{ .serviceName }}\", dt.endpoint.name == \"{{ .endpointName }}\"},\n  nonempty: true\n| fieldsAdd metricName = \"Response time p50\""
      },
      {
        "key": "alertOnMissingData",
        "value": "false"
      },
      {
        "key": "violatingSamples",
        "value": "3"
      },
      {
        "key": "threshold",
        "value": "{{ .threshold }}"
      },
      {
        "key": "dealertingSamples",
        "value": "5"
      },
      {
        "key": "slidingWindow",
        "value": "5"
      },
      {
        "key": "alertCondition",
        "value": "ABOVE"
      }
    ]
  },
  "eventTemplate": {
    "properties": [
      {
        "key": "dt.source_entity",
        "value": "{dims:dt.source_entity}"
      },
      {
        "key": "event.type",
        "value": "CUSTOM_ALERT"
      },
      {
        "key": "event.description",
        "value": "❗**Alert description:**\nAn anomaly was detected on {metricname}. Within the sliding window, {violating_samples} violation samples were detected that were {alert_condition} the threshold of {threshold}."
      },
      {
        "key": "event.name",
        "value": "{{ .title }}"
      }
    ]
  }
}
